TURSO_DATABASE_URL=
TURSO_AUTH_TOKEN=
# Per-instance org id (constant tenant_id). NOT user-supplied.
CORTEXT_ORG_ID=default
# Dev bypass token. Optional — only active when set to a non-empty value.
# In production, leave unset and use real user tokens instead.
CORTEXT_DEV_TOKEN=
# First admin bootstrap. Set both to auto-create admin on first boot.
# The password is hashed with argon2id via hash-wasm.
ADMIN_USERNAME=
ADMIN_PASSWORD=
# JWT secret for admin panel session tokens. Must be at least 32 characters.
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET=
AUTH_ISSUER_URL=https://example.com
MCP_REQUIRED_SCOPES=read:memories
