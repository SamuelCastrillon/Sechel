TURSO_DATABASE_URL=
TURSO_AUTH_TOKEN=
# Per-instance org id (constant tenant_id). NOT user-supplied.
CORTEXT_ORG_ID=default
# SLICE 1 DEV BYPASS: a single dev token mapped to the seeded admin account.
# Real bearer -> users auth lands in Slice 3. Replace before any production use.
CORTEXT_DEV_TOKEN=dev-admin-token
AUTH_ISSUER_URL=https://example.com
MCP_REQUIRED_SCOPES=read:memories
