# ─────────────────────────────────────────────────────────────────────────────
# Sechel — Environment Variables
# ─────────────────────────────────────────────────────────────────────────────

## Database (Turso / libSQL)
DATABASE_URL=libsql://your-database.turso.io
DATABASE_AUTH_TOKEN=
# Optional: scopes all data to a logical tenant
TENANT_ID=default

## Auth (MCP endpoint)
# Bearer token that clients must send as Authorization: Bearer <token>
# Leave unset for development (no auth required)
# This is optional — user-level tokens stored in the database also work.
SECHEL_ADMIN_TOKEN=
# Dev bypass — only active when set to a non-empty value.
# In production, leave unset and use SECHEL_ADMIN_TOKEN or real user tokens.
SECHEL_DEV_TOKEN=

## Admin Panel (future Preact SPA — for when panel is enabled)
# Bootstrap first admin on empty instance
ADMIN_USERNAME=admin
ADMIN_PASSWORD=
# JWT secret for admin session tokens. Must be at least 32 characters.
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET=

## Legacy (Next.js panel — backward compat, will be removed in v0.4.0)
SECHEL_ORG_ID=default
MCP_REQUIRED_SCOPES=read:memories
AUTH_ISSUER_URL=https://example.com
